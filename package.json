{
  "name": "@gcombrinck/playwright-llm-reporter",
  "version": "1.0.2",
  "description": "Custom Playwright reporter that generates interactive HTML reports with optional LLM integration",
  "author": "Garth Combrinck <gcombrinck@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gcombrinck/playwright-llm-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/gcombrinck/playwright-llm-reporter/issues"
  },
  "homepage": "https://github.com/gcombrinck/playwright-llm-reporter#readme",
  "keywords": [
    "playwright",
    "reporter",
    "html",
    "llm",
    "openai",
    "testing",
    "e2e"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/reporters/llm-html-reporter.js",
  "types": "dist/reporters/llm-html-reporter.d.ts",
  "exports": {
    ".": {
      "import": "./dist/reporters/llm-html-reporter.js",
      "require": "./dist/reporters/llm-html-reporter.js",
      "types": "./dist/reporters/llm-html-reporter.d.ts"
    },
    "./llm-server": {
      "import": "./dist/llm-server.js",
      "require": "./dist/llm-server.js",
      "types": "./dist/llm-server.d.ts"
    }
  },
  "bin": {
    "llm-server": "./dist/bin/llm-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "llm-server": "ts-node llm-server.ts",
    "build": "tsc -p .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "openai": "^4.58.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
